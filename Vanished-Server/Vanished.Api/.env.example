POSTGRES_DB=vanished
POSTGRES_USER=vanished
POSTGRES_PASSWORD=replace-with-a-unique-strong-postgres-password
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql+psycopg2://vanished:replace-with-a-unique-strong-postgres-password@db:5432/vanished
JWT_SECRET_KEY=replace-with-a-unique-64-byte-random-secret
TOKEN_PEPPER=replace-with-a-unique-64-byte-random-secret
MFA_SECRET_ENCRYPTION_KEY=replace-with-32-random-bytes-base64
RATE_LIMIT_STORAGE=redis://redis:6379/1
REDIS_URL=redis://redis:6379/0
CORS_ALLOWED_ORIGINS=https://vanished.pt,https://www.vanished.pt,https://api.vanished.pt
ACCESS_TOKEN_EXP_MINUTES=15
REFRESH_TOKEN_EXP_DAYS=14
REQUEST_SIGNATURE_MAX_SKEW_SECONDS=120

AUTO_CREATE_SCHEMA=false
ACCOUNT_PIN_PEPPER=replace-with-a-unique-64-byte-random-secret
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=no-reply@example.pt
SMTP_FROM_NAME=example
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true
SMTP_TIMEOUT_SECONDS=10
BLOCKED_REGISTRATION_EMAIL_DOMAINS=test.com,example.com,example.org,example.net,invalid,localhost,local
